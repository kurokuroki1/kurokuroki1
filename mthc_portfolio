        <!-- Check-Contrast -->
        <div class="project-card">
          <div class="project-content">
            <div class="project-number">02</div>
            <h2 class="project-name">Check-Contrast</h2>
            <p class="project-desc">
              A real-time WCAG 2.1 colour contrast checker with colour blindness simulation and one-click
